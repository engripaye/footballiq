APP_NAME=FootballIQ
APP_ENV=development
DATABASE_URL=sqlite:///./footballiq.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SEED_DEMO_DATA=true
FOOTBALL_DATA_API_KEY=replace_with_your_football_data_org_token
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FIXTURE_SYNC_ENABLED=true
AUTO_SYNC_ON_STARTUP=false
SYNC_REQUEST_DELAY_SECONDS=6.5
DEFAULT_TIMEZONE=Africa/Lagos

# Production overrides (set in the hosting dashboard, never commit secrets):
# APP_ENV=production
# DATABASE_URL=postgresql+psycopg2://...
# CORS_ORIGINS=https://your-footballiq-frontend.example
# SEED_DEMO_DATA=false
